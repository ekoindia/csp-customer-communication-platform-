# ============================================================
# CSP Platform — environment config TEMPLATE.
# Copy this file to ".env" (gitignored, never committed) and fill in real
# values there. This file itself must never contain real secrets.
# ============================================================

# ── Admin-portal reporting (this CSP install -> Eko admin portal) ──────────
ADMIN_REPORT_ENABLED=0
ADMIN_API_BASE=http://127.0.0.1:7000/api/v1
ADMIN_CSP_ID=CSP001
ADMIN_API_KEY=demo-key-CSP001

# ── Admin-portal SERVER binding (only used when running admin_portal/app.py) ─
ADMIN_BIND_HOST=127.0.0.1
ADMIN_BIND_PORT=7000

# ============================================================
# RAG Credentials
# ============================================================
rag_server_host_ip=
rag_server_port=
rag_server_pass=
